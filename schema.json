{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/DanielFerrariR/rulelayers/main/schema.json",
  "title": "rulelayers configuration",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "layers": {
      "type": "array",
      "minItems": 1,
      "description": "Layers from lowest to highest precedence. Strings map to .rulesync.{name}/; objects may pull from an npm package.",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Layer name (used for logging). Defaults from the package basename when omitted."
              },
              "package": {
                "type": "string",
                "minLength": 1,
                "description": "npm package to read as this layer (e.g. @acme/ai-rules)"
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "Subpath inside the package (overrides package.json rulelayers root)"
              }
            },
            "additionalProperties": false,
            "anyOf": [{ "required": ["name"] }, { "required": ["package"] }]
          }
        ]
      }
    },
    "rulesync": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "Executable to run after merge (default: rulesync)"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments passed to the rulesync command"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["layers"],
  "additionalProperties": false
}
