{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "style": "off",
    "pedantic": "off"
  },
  "rules": {
    "eqeqeq": "error",
    "no-console": "error",
    "no-underscore-dangle": ["warn", { "allow": ["__test"] }],
    "unicorn/prefer-node-protocol": "error"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist/**", "coverage/**", "node_modules/**", "*.d.ts"],
  "overrides": [
    {
      "files": ["src/cli.ts", "src/commands/**/*.ts", "src/rulesync.ts", "src/merge.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "tests/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
