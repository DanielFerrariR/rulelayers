{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/danielrey/rulelayers/schema.json",
  "title": "rulelayers configuration",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "layers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Layer names from lowest to highest precedence. Each maps to .rulesync.{name}/"
    },
    "rulesync": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "Executable to run after merge (default: rulesync)"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments passed to the rulesync command"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["layers"],
  "additionalProperties": false
}
