{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "ignorePatterns": ["package.json", "pnpm-lock.yaml", "node_modules/**", "dist/**", "coverage/**"]
}
