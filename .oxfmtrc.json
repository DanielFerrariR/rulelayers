{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "ignorePatterns": [
    "package.json",
    "package-lock.json",
    "node_modules/**",
    "dist/**",
    "coverage/**"
  ]
}
